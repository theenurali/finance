[Unit]
Description=Telegram Finance Bot
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/finance-bot
EnvironmentFile=/opt/finance-bot/.env
ExecStart=/opt/finance-bot/.venv/bin/python /opt/finance-bot/main.py
Restart=always
RestartSec=5

# Security hardening (safe defaults)
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/finance-bot

[Install]
WantedBy=multi-user.target

